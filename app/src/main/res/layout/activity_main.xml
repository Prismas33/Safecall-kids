<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/primary_color"
            android:gravity="center_vertical"
            android:minHeight="96dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/app_logo_content_description"
                android:src="@drawable/logo_safecall_transparent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="@string/app_name"
                    android:textColor="@color/header_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/protection_description"
                    android:textColor="@color/header_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:contentDescription="@string/protection_icon_content_description"
                android:src="@drawable/ic_shield_heart" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/language_label"
                android:textColor="@color/secondary_text_color"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btn_lang_pt"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Português"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_flag_pt" />

            <ImageButton
                android:id="@+id/btn_lang_en"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="English"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_flag_en" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/panel_card_bg"
            android:elevation="3dp"
            android:minHeight="108dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingMultiplier="1.15"
                android:text="@string/protection_inactive"
                android:textColor="@color/text_color"
                android:textSize="19sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/setupProtectionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/button_primary"
            android:text="@string/setup_protection"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/verifyButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/button_primary"
                android:text="@string/verify_and_activate"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/deactivateButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/button_primary"
                android:text="@string/deactivate_protection"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/panel_card_bg"
                android:elevation="2dp"
                android:gravity="center"
                android:minHeight="76dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/contactsCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/contacts_loaded"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/panel_card_bg"
                android:elevation="2dp"
                android:gravity="center"
                android:minHeight="76dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/blockedCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/calls_blocked"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/monetizationPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/panel_card_bg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/monetizationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/premium_title"
                android:textColor="@color/text_color"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/monetizationStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/premium_state_loading"
                android:textColor="@color/secondary_text_color"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/premiumDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingMultiplier="1.2"
                android:text="@string/premium_description"
                android:textColor="@color/secondary_text_color"
                android:textSize="13sp" />

            <Button
                android:id="@+id/unlockPremiumButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_primary"
                android:text="@string/premium_unlock_loading"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/billingDisclaimerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/premium_disclaimer"
                android:textColor="@color/secondary_text_color"
                android:textSize="12sp" />

        </LinearLayout>

        <Button
            android:id="@+id/instructionsButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/button_secondary"
            android:text="@string/detailed_instructions"
            android:textColor="@color/text_color"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/parentalControlButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/button_secondary"
            android:text="@string/parental_control_button"
            android:textColor="@color/text_color"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_card_bg"
            android:lineSpacingMultiplier="1.35"
            android:padding="16dp"
            android:text="@string/info_text"
            android:textColor="@color/secondary_text_color"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/footer_text"
            android:textColor="@color/secondary_text_color"
            android:textSize="10sp" />

    </LinearLayout>
</ScrollView>
