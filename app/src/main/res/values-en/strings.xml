    <!-- Android 13+ Instructions -->
    <string name="android_13_instructions">🛡️ COMPLETE SETUP FOR ANDROID 13+\n\n⚡ QUICK METHOD - Set as Default App:\n1. Settings → Apps → Default apps → Phone app\n2. Select \'SafecallKids\'\n3. Confirm the change\n\n📞 ALTERNATIVE - Through Phone App:\n1. Open system \'Phone\' app\n2. Menu (⋮) → Settings\n3. Look for \'Spam blocking\' or \'Caller ID\'\n4. Enable SafecallKids\n\n🔍 IF NOT FOUND:\n1. Settings → Privacy and security\n2. Permissions → Phone\n3. Enable all for SafecallKids</string>
    
    <!-- Android 12 Instructions -->
    <string name="android_12_instructions">🛡️ SETUP FOR ANDROID 12\n\n1️⃣ Set as default phone app:\n   Settings → Apps → Default apps → Phone\n\n2️⃣ Enable Call Screening:\n   Settings → Apps → Special permissions\n   → Call screening services\n\n3️⃣ Phone permissions:\n   Settings → Privacy → Permissions\n   → Phone → SafecallKids → Allow</string>
    
    <!-- Android 10-11 Instructions -->
    <string name="android_10_instructions">🛡️ SETUP FOR ANDROID 10-11\n\n1️⃣ Default apps:\n   Settings → Apps → Default apps → Phone app\n\n2️⃣ Call Screening:\n   Settings → Apps → Special permissions\n   → Call information access\n\n3️⃣ Check permissions:\n   - Phone: Allowed\n   - Contacts: Allowed\n   - Display over other apps: Allowed</string>
    
    <!-- Android Legacy Instructions -->
    <string name="android_legacy_instructions">🛡️ SETUP FOR ANDROID 9 AND EARLIER\n\n✅ Basic permissions are sufficient for this version!\n\nThe app will use legacy blocking method:\n- Phone permission\n- Contacts permission\n- Display over other apps permission\n\nClick \'Already configured\' to activate.</string>
    
